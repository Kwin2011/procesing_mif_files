    "replacement": "\\1'>\n>",
    "description": "Clear TIMLeadOfficeReleasedRD value NE1"
  },
  {
    "pattern": "(<VariableName\\s*`SCHLeadOffice'?>\\s*<VariableDef\\s*`)(.*?)'",
    "replacement": "\\1'",
